# Supabase — copy this file to .env and fill in your values
# Get these from: https://supabase.com/dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Deployment Notes (Vercel) ─────────────────────────────
# 1. Add VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY
#    in Vercel → Project Settings → Environment Variables
# 2. Both must be set for ALL environments (Production, Preview, Development)
# 3. Supabase dashboard → Authentication → URL Configuration:
#    Add your Vercel domain to "Redirect URLs"
# 4. Supabase dashboard → Settings → API → Allowed Origins:
#    Add https://your-app.vercel.app
